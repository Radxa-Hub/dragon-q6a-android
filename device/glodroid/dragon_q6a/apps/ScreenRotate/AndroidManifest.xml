<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dragonq6a.screenrotate">

    <!-- Signature permission; granted because the app is signed with the
         platform key. Lets us call IWindowManager.freezeRotation(). -->
    <uses-permission android:name="android.permission.SET_ORIENTATION" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_screen_rotate"
        android:allowBackup="false"
        android:supportsRtl="true">

        <activity
            android:name=".RotateActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.DeviceDefault.Light.DarkActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".RotateTileService"
            android:exported="true"
            android:icon="@drawable/ic_screen_rotate"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>
</manifest>
