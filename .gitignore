# Full SD card images (8 GB each) — too large for git; the ready-to-flash
# community image ships as a GitHub Release asset (community_v1.img.zst).
*.img.zst
dragon_q6a_sd_*.img
userdata*.img
metadata*.img
super.img

# Build-staged duplicates (regenerated by gensdimg-uefi.sh from prebuilt/ + ramdisk)
device/glodroid/dragon_q6a/esp/Android/Image
device/glodroid/dragon_q6a/esp/Android/ramdisk.img
device/glodroid/dragon_q6a/esp/Android/*.dtb

# AOSP/GloDroid build output
out/
*.o
*.zip

# Windows "Zone.Identifier" alternate-data-stream droppings (WSL)
*:Zone.Identifier
*.Zone.Identifier

# Editor / OS noise
.DS_Store
*.swp

# Third-party APKs are fetched, not committed (see scripts/fetch-lawnchair.sh)
*.apk
