					phandle = <0x2a7>;
				};

				camera0-crit {
					temperature = <0x1adb0>;
					hysteresis = <0x00>;
					type = "critical";
					phandle = <0x2a8>;
				};
			};
		};

		pm7250b-thermal {
			polling-delay-passive = <0x64>;
			thermal-sensors = <0x18c>;

			trips {

				trip0 {
					temperature = <0x17318>;
					hysteresis = <0x00>;
					type = "passive";
				};

				trip1 {
					temperature = <0x1c138>;
					hysteresis = <0x00>;
					type = "hot";
				};

				trip2 {
					temperature = <0x23668>;
					hysteresis = <0x00>;
					type = "critical";
				};
			};
		};

		pm7325-thermal {
			polling-delay-passive = <0x64>;
			thermal-sensors = <0x18d>;
			phandle = <0x2a9>;

			trips {

				trip0 {
					temperature = <0x17318>;
					hysteresis = <0x00>;
					type = "passive";
					phandle = <0x2aa>;
				};

				pm7325-crit {
					temperature = <0x1c138>;
					hysteresis = <0x00>;
					type = "critical";
					phandle = <0x2ab>;
				};
			};
		};

		pm8350c-thermal {
			polling-delay-passive = <0x64>;
			thermal-sensors = <0x18e>;
			phandle = <0x2ac>;

			trips {

				trip0 {
					temperature = <0x17318>;
					hysteresis = <0x00>;
					type = "passive";
					phandle = <0x2ad>;
				};

				pm8350c-crit {
					temperature = <0x1c138>;
					hysteresis = <0x00>;
					type = "critical";
					phandle = <0x2ae>;
				};
			};
		};

		msm-skin-thermal {
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x18f 0x02>;
		};

		quiet-thermal {
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x18f 0x01>;
		};

		ufs-thermal {
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x18f 0x03>;
		};

		xo-thermal {
			polling-delay-passive = <0x00>;
			thermal-sensors = <0x18f 0x00>;
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0x08 0x01 0x0e 0x08 0x01 0x0b 0x08 0x01 0x0a 0x08>;
	};

	reboot-mode {
		compatible = "nvmem-reboot-mode";
		nvmem-cells = <0x190>;
		nvmem-cell-names = "reboot-mode";
		mode-recovery = <0x01>;
		mode-bootloader = <0x02>;
	};

	audio-codec {
		compatible = "qcom,wcd9380-codec";
		pinctrl-0 = <0x191>;
		pinctrl-names = "default";
		reset-gpios = <0xc0 0x53 0x01>;
		vdd-rxtx-supply = <0x192>;
		vdd-io-supply = <0x192>;
		vdd-buck-supply = <0x193>;
		vdd-mic-bias-supply = <0x162>;
		qcom,micbias1-microvolt = <0x1b7740>;
		qcom,micbias2-microvolt = <0x1b7740>;
		qcom,micbias3-microvolt = <0x1b7740>;
		qcom,micbias4-microvolt = <0x1b7740>;
		qcom,mbhc-buttons-vthreshold-microvolt = <0x124f8 0x249f0 0x39dc8 0x7a120 0x7a120 0x7a120 0x7a120 0x7a120>;
		qcom,mbhc-headset-vthreshold-microvolt = <0x19f0a0>;
		qcom,mbhc-headphone-vthreshold-microvolt = <0xc350>;
		qcom,rx-device = <0x194>;
		qcom,tx-device = <0x195>;
		qcom,hphl-jack-type-normally-closed;
		#sound-dai-cells = <0x01>;
		phandle = <0x168>;
	};

	connector-0 {
		compatible = "usb-a-connector";
		vbus-supply = <0x124>;
		phandle = <0x2af>;

		port {

			endpoint {
				remote-endpoint = <0x196>;
				phandle = <0x125>;
			};
		};
	};

	connector-1 {
		compatible = "usb-a-connector";
		vbus-supply = <0x124>;
		phandle = <0x2b0>;

		port {

			endpoint {
				remote-endpoint = <0x197>;
				phandle = <0x126>;
			};
		};
	};

	connector-2 {
		compatible = "usb-a-connector";
		vbus-supply = <0x124>;
		phandle = <0x2b1>;

		port {

			endpoint {
				remote-endpoint = <0x198>;
				phandle = <0x127>;
			};
		};
	};

	connector {
		compatible = "usb-a-connector";
		phandle = <0x2b2>;

		ports {
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			port@0 {
				reg = <0x00>;

				endpoint {
					remote-endpoint = <0x199>;
					phandle = <0x134>;
				};
			};

			port@1 {
				reg = <0x01>;

				endpoint {
					remote-endpoint = <0x19a>;
					phandle = <0x11f>;
				};
			};
		};
	};

	hdmi-bridge {
		compatible = "radxa,ra620";
		pinctrl-0 = <0x19b>;
		pinctrl-names = "default";

		ports {
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			port@0 {
				reg = <0x00>;

				endpoint {
					remote-endpoint = <0x19c>;
					phandle = <0x11e>;
				};
			};

			port@1 {
				reg = <0x01>;

				endpoint {
					remote-endpoint = <0x19d>;
					phandle = <0x19e>;
				};
			};
		};
	};

	hdmi-connector {
		compatible = "hdmi-connector";
		label = "hdmi";
		type = "a";

		port {

			endpoint {
				remote-endpoint = <0x19e>;
				phandle = <0x19d>;
			};
		};
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-0 = <0x19f>;
		pinctrl-names = "default";

		user-led {
			color = <0x03>;
			function = "status";
			gpios = <0xc0 0x2a 0x00>;
			linux,default-trigger = "heartbeat";
		};
	};

	regulator-vcc-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		vin-supply = <0x124>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x2b3>;
	};

	regulator-vcc-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		vin-supply = <0x124>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x2b4>;
	};

	regulator-vcc-5v-peri {
		compatible = "regulator-fixed";
		regulator-name = "vcc_5v_peri";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		vin-supply = <0x160>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x124>;
	};

	regulator-vph-pwr {
		compatible = "regulator-fixed";
		regulator-name = "vph_pwr";
		regulator-min-microvolt = <0x387520>;
		regulator-max-microvolt = <0x387520>;
		regulator-boot-on;
		regulator-always-on;
		phandle = <0x160>;
	};

