/dts-v1/;

/ {
	interrupt-parent = <0x01>;
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	model = "Radxa Dragon Q6A";
	compatible = "radxa,dragon-q6a\0qcom,qcm6490";
	chassis-type = "embedded";

	chosen {
		stdout-path = "serial0:115200n8";
	};

	aliases {
		i2c0 = "/soc@0/geniqup@9c0000/i2c@980000";
		i2c1 = "/soc@0/geniqup@9c0000/i2c@984000";
		i2c2 = "/soc@0/geniqup@9c0000/i2c@988000";
		i2c3 = "/soc@0/geniqup@9c0000/i2c@98c000";
		i2c4 = "/soc@0/geniqup@9c0000/i2c@990000";
		i2c5 = "/soc@0/geniqup@9c0000/i2c@994000";
		i2c6 = "/soc@0/geniqup@9c0000/i2c@998000";
		i2c7 = "/soc@0/geniqup@9c0000/i2c@99c000";
		i2c8 = "/soc@0/geniqup@ac0000/i2c@a80000";
		i2c9 = "/soc@0/geniqup@ac0000/i2c@a84000";
		i2c10 = "/soc@0/geniqup@ac0000/i2c@a88000";
		i2c11 = "/soc@0/geniqup@ac0000/i2c@a8c000";
		i2c12 = "/soc@0/geniqup@ac0000/i2c@a90000";
		i2c13 = "/soc@0/geniqup@ac0000/i2c@a94000";
		i2c14 = "/soc@0/geniqup@ac0000/i2c@a98000";
		i2c15 = "/soc@0/geniqup@ac0000/i2c@a9c000";
		i2c16 = "/soc@0/cci@ac4a000/i2c-bus@0";
		i2c17 = "/soc@0/cci@ac4a000/i2c-bus@1";
		i2c18 = "/soc@0/cci@ac4b000/i2c-bus@0";
		i2c19 = "/soc@0/cci@ac4b000/i2c-bus@0";
		mmc1 = "/soc@0/mmc@8804000";
		mmc2 = "/soc@0/mmc@8804000";
		spi0 = "/soc@0/geniqup@9c0000/spi@980000";
		spi1 = "/soc@0/geniqup@9c0000/spi@984000";
		spi2 = "/soc@0/geniqup@9c0000/spi@988000";
		spi3 = "/soc@0/geniqup@9c0000/spi@98c000";
		spi4 = "/soc@0/geniqup@9c0000/spi@990000";
		spi5 = "/soc@0/geniqup@9c0000/spi@994000";
		spi6 = "/soc@0/geniqup@9c0000/spi@998000";
		spi7 = "/soc@0/geniqup@9c0000/spi@99c000";
		spi8 = "/soc@0/geniqup@ac0000/spi@a80000";
		spi9 = "/soc@0/geniqup@ac0000/spi@a84000";
		spi10 = "/soc@0/geniqup@ac0000/spi@a88000";
		spi11 = "/soc@0/geniqup@ac0000/spi@a8c000";
		spi12 = "/soc@0/geniqup@ac0000/spi@a90000";
		spi13 = "/soc@0/geniqup@ac0000/spi@a94000";
		spi14 = "/soc@0/geniqup@ac0000/spi@a98000";
		spi15 = "/soc@0/geniqup@ac0000/spi@a9c000";
		mmc0 = "/soc@0/mmc@7c4000";
		serial0 = "/soc@0/geniqup@9c0000/serial@994000";
	};

	clocks {

		xo-board {
			compatible = "fixed-clock";
			clock-frequency = <0x493e000>;
			#clock-cells = <0x00>;
			phandle = <0x15f>;
		};

		sleep-clk {
			compatible = "fixed-clock";
			clock-frequency = <0x7ffc>;
			#clock-cells = <0x00>;
			phandle = <0x34>;
		};
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		hyp@80000000 {
			reg = <0x00 0x80000000 0x00 0x600000>;
			no-map;
			phandle = <0x1a0>;
		};

		xbl@80600000 {
			reg = <0x00 0x80600000 0x00 0x200000>;
			no-map;
			phandle = <0x1a1>;
		};

		aop@80800000 {
			reg = <0x00 0x80800000 0x00 0x60000>;
			no-map;
			phandle = <0x1a2>;
		};

		aop-cmd-db@80860000 {
			reg = <0x00 0x80860000 0x00 0x20000>;
			compatible = "qcom,cmd-db";
			no-map;
			phandle = <0x1a3>;
		};

		xbl-uefi-res@80880000 {
			reg = <0x00 0x80884000 0x00 0x10000>;
			no-map;
			phandle = <0x1a4>;
		};

		sec-apps@808ff000 {
			reg = <0x00 0x808ff000 0x00 0x1000>;
			no-map;
			phandle = <0x1a5>;
		};

		smem@80900000 {
			reg = <0x00 0x80900000 0x00 0x200000>;
			no-map;
			phandle = <0x24>;
		};

		cpucp@80b00000 {
			no-map;
			reg = <0x00 0x80b00000 0x00 0x100000>;
			phandle = <0x1a6>;
		};

		lpass-ml@81800000 {
			reg = <0x00 0x81800000 0x00 0xf00000>;
			no-map;
			phandle = <0x1a7>;
		};

		cdsp-secure-heap@82700000 {
			reg = <0x00 0x82700000 0x00 0x10000>;
			no-map;
			phandle = <0x1a8>;
		};

		adsp@8b800000 {
			reg = <0x00 0x8b800000 0x00 0x2800000>;
			no-map;
			phandle = <0x12a>;
		};

		cdsp@8e000000 {
			reg = <0x00 0x8e000000 0x00 0x1e00000>;
			no-map;
			phandle = <0x131>;
		};

		video@8fe00000 {
			reg = <0x00 0x8fe00000 0x00 0x500000>;
			no-map;
			phandle = <0x139>;
		};

		zap@90300000 {
			reg = <0x00 0x90300000 0x00 0x5000>;
			no-map;
			phandle = <0xea>;
		};

		tz-stat@c0000000 {
			reg = <0x00 0xc0000000 0x00 0x100000>;
			no-map;
			phandle = <0x1a9>;
		};

		tags@c0100000 {
			reg = <0x00 0xc0100000 0x00 0x1200000>;
			no-map;
			phandle = <0x1aa>;
		};

		qtee@c1300000 {
			reg = <0x00 0xc1300000 0x00 0x500000>;
			no-map;
			phandle = <0x1ab>;
		};

		trusted-apps@c1800000 {
			reg = <0x00 0xc1800000 0x00 0x2200000>;
			no-map;
			phandle = <0x1ac>;
		};

		adsp-rpc-remote-heap@c6500000 {
			reg = <0x00 0xc6500000 0x00 0x800000>;
			no-map;
			phandle = <0x1ad>;
		};
	};

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		cpu@0 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x00>;
			clocks = <0x02 0x00>;
			enable-method = "psci";
			power-domains = <0x03>;
			power-domain-names = "psci";
			next-level-cache = <0x04>;
			operating-points-v2 = <0x05>;
			capacity-dmips-mhz = <0x400>;
			dynamic-power-coefficient = <0x64>;
			interconnects = <0x06 0x02 0x03 0x07 0x01 0x03 0x08 0x00 0x08 0x01>;
			qcom,freq-domain = <0x02 0x00>;
			#cooling-cells = <0x02>;
			phandle = <0x1a>;

			l2-cache {
				compatible = "cache";
				cache-level = <0x02>;
				cache-unified;
				next-level-cache = <0x09>;
				phandle = <0x04>;

				l3-cache {
					compatible = "cache";
					cache-level = <0x03>;
					cache-unified;
					phandle = <0x09>;
				};
			};
		};

		cpu@100 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x100>;
			clocks = <0x02 0x00>;
			enable-method = "psci";
			power-domains = <0x0a>;
			power-domain-names = "psci";
			next-level-cache = <0x0b>;
			operating-points-v2 = <0x05>;
			capacity-dmips-mhz = <0x400>;
			dynamic-power-coefficient = <0x64>;
			interconnects = <0x06 0x02 0x03 0x07 0x01 0x03 0x08 0x00 0x08 0x01>;
			qcom,freq-domain = <0x02 0x00>;
			#cooling-cells = <0x02>;
			phandle = <0x1b>;

			l2-cache {
				compatible = "cache";
				cache-level = <0x02>;
				cache-unified;
				next-level-cache = <0x09>;
				phandle = <0x0b>;
