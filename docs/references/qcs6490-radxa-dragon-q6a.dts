			cluster-sleep-1 {
				compatible = "domain-idle-state";
				arm,psci-suspend-param = <0x41001344>;
				entry-latency-us = <0xcbf>;
				exit-latency-us = <0x11d2>;
				min-residency-us = <0x2113>;
				phandle = <0x2d>;
			};

			cluster-sleep-2 {
