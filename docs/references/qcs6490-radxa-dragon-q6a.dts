				cache-unified;
				next-level-cache = <0x09>;
				phandle = <0x11>;
			};
		};

		cpu@500 {
			device_type = "cpu";
			compatible = "qcom,kryo";
			reg = <0x00 0x500>;
			clocks = <0x02 0x01>;
			enable-method = "psci";
			power-domains = <0x13>;
			power-domain-names = "psci";
